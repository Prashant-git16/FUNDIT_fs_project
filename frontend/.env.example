# FundIt Frontend — Environment Variables Template
# ═══════════════════════════════════════════════

# URL of the Backend API (Use http://localhost:5000 for local development)
REACT_APP_API_URL=http://localhost:5000

# Razorpay Public Key ID (Required for checkout modal)
REACT_APP_RAZORPAY_KEY=rzp_test_your_key_id_here
